{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2023"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "allowJs": true,
    "noEmit": true
  },
  "include": [
    "src/**/*.ts",
    "../web/src/lib/ranks.ts",
    "../web/src/lib/modes.ts",
    "../web/src/lib/ocr.ts",
    "../web/src/lib/db.ts"
  ]
}
