# Jeton du bot (Discord Developer Portal → Bot → Reset Token)
DISCORD_TOKEN="..."
# ID de l'application (Developer Portal → General Information → Application ID)
DISCORD_CLIENT_ID="..."
# ID de ton serveur Discord (clic droit sur le serveur → Copier l'identifiant ; mode dev activé)
DISCORD_GUILD_ID="..."

# MÊME base que le site web (Postgres Neon). Copie la même valeur que dans Vercel.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
