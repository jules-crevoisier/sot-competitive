# Base de données Postgres (Neon, Supabase, Vercel Postgres…)
# En local : crée un .env et colle ton URL ici.
# En prod : définis cette variable dans les réglages Vercel.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"

# — Connexion Discord (OAuth2) —
# Tant que ces variables sont absentes, l'auth est désactivée et le sélecteur de
# pirate "dev" reste actif (pratique en local / pour les tests E2E).
# Developer Portal → ton app → OAuth2. Ajoute la Redirect URL :
#   http://localhost:3000/api/auth/callback   (et l'équivalent https en prod)
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
# ID du serveur Discord requis pour se connecter (laisser vide = aucun contrôle)
DISCORD_GUILD_ID=""
# Clé de signature des cookies de session (ex: openssl rand -hex 32)
AUTH_SECRET=""
# URL publique de l'app (sert à construire les redirections OAuth)
AUTH_BASE_URL="http://localhost:3000"
